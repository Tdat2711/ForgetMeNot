
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- Background Circle -->
  <circle cx="100" cy="100" r="100" fill="#334155"/>
  
  <!-- Body -->
  <circle cx="100" cy="130" r="50" fill="#475569"/>
  
  <!-- Head -->
  <circle cx="100" cy="75" r="40" fill="#64748B"/>
  
  <!-- Eyes -->
  <circle cx="85" cy="70" r="5" fill="#CBD5E1"/>
  <circle cx="115" cy="70" r="5" fill="#CBD5E1"/>
  
  <!-- Smile -->
  <path d="M85,85 Q100,100 115,85" stroke="#CBD5E1" stroke-width="3" fill="none" stroke-linecap="round"/>
</svg>